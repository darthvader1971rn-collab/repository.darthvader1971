    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="pl-pl">Wtyczka IPTV 3.0</summary>
        <summary lang="en-gb">IPTV 3.0 Addon</summary>

        <description lang="pl-pl">
            Modularny, odporny i inteligentny system odtwarzania IPTV.
        </description>
        <description lang="en-gb">
            Modular, resilient and intelligent IPTV playback system.
        </description>

        <platform>all</platform>

        <language>pl-pl</language>
        <language>en-gb</language>

        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>

</addon><addon id="repository.darthvader1971" name="DarthVader1971 Repository" version="1.0.0" provider-name="DarthVader1971">
